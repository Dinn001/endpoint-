{
  "version": 2,
  "builds": [
    {
      "src": "api/[...route.js]",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/[...route.js]"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
